@using Microsoft.AspNetCore.Components.Forms
@using UserGroupSite.Shared.Events
@using UserGroupSite.Shared.Services
@inject IMarkdownService MarkdownService

<EditForm Model="Input" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <fieldset disabled="@IsSubmitting">
        <div class="form-floating mb-3">
            <InputText @bind-Value="Input.Name" id="Input.Name" class="form-control" placeholder="Event name" @onblur="HandleNameBlur" />
            <label for="Input.Name">Name</label>
            <ValidationMessage For="() => Input.Name" class="text-danger" />
        </div>

        <div class="form-floating mb-3">
            <InputText @bind-Value="Input.Slug" id="Input.Slug" class="form-control" placeholder="event_name" readonly="@IsEditMode" />
            <label for="Input.Slug">
                Slug
                @if (IsEditMode)
                {
                    <span class="text-muted">(cannot be changed)</span>
                }
            </label>
            <ValidationMessage For="() => Input.Slug" class="text-danger" />
        </div>

        <div class="form-floating mb-3">
            <InputText @bind-Value="Input.ShortDescription" id="Input.ShortDescription" class="form-control" placeholder="A brief summary of the event" />
            <label for="Input.ShortDescription">Short Description</label>
            <ValidationMessage For="() => Input.ShortDescription" class="text-danger" />
        </div>

        <div class="mb-3">
            <label class="form-label">Description <span class="text-muted small">(Markdown supported)</span></label>
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link @(descriptionTab == "edit" ? "active" : "")"
                            role="tab" @onclick='() => descriptionTab = "edit"'>
                        <i class="bi bi-pencil"></i> Edit
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button type="button" class="nav-link @(descriptionTab == "preview" ? "active" : "")"
                            role="tab" @onclick="ShowPreview">
                        <i class="bi bi-eye"></i> Preview
                    </button>
                </li>
            </ul>
            <div class="tab-content border border-top-0 rounded-bottom p-3">
                @if (descriptionTab == "edit")
                {
                    <InputTextArea @bind-Value="Input.Description" id="Input.Description" class="form-control" placeholder="Event description" style="min-height: 200px;" />
                    <ValidationMessage For="() => Input.Description" class="text-danger" />
                }
                else
                {
                    @if (string.IsNullOrWhiteSpace(Input.Description))
                    {
                        <p class="text-muted fst-italic mb-0">Nothing to preview.</p>
                    }
                    else
                    {
                        <div class="markdown-preview">
                            @((MarkupString)descriptionHtml)
                        </div>
                    }
                }
            </div>
        </div>

        <div class="form-floating mb-3">
            <InputText @bind-Value="Input.EventDateTimeLocal" id="Input.EventDateTimeLocal" type="datetime-local" class="form-control" />
            <label for="Input.EventDateTimeLocal">Event date/time</label>
            <ValidationMessage For="() => Input.EventDateTimeLocal" class="text-danger" />
        </div>

        <div class="form-floating mb-3">
            <InputText @bind-Value="Input.Location" id="Input.Location" class="form-control" placeholder="Location" />
            <label for="Input.Location">Location</label>
            <ValidationMessage For="() => Input.Location" class="text-danger" />
        </div>

        <div class="mb-3">
            <div class="form-check form-switch">
                <InputCheckbox @bind-Value="Input.IsPublished" id="Input.IsPublished" class="form-check-input" />
                <label class="form-check-label" for="Input.IsPublished">
                    Published
                    <span class="text-muted small d-block">Only published events are visible to non-admin users</span>
                </label>
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Speakers</label>
            @if (IsSpeakersLoading)
            {
                <p>Loading speakers...</p>
            }
            else if (!string.IsNullOrWhiteSpace(SpeakersError))
            {
                <div class="text-danger">@SpeakersError</div>
            }
            else if (SpeakerOptions is null || SpeakerOptions.Count == 0)
            {
                <p>No eligible speakers found.</p>
            }
            else
            {
                @foreach (var speaker in SpeakerOptions)
                {
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               checked="@Input.SpeakerIds.Contains(speaker.Id)"
                               @onchange="args => ToggleSpeaker(speaker.Id, args)" />
                        <label class="form-check-label">
                            @speaker.DisplayName (@speaker.Email)
                        </label>
                    </div>
                }
            }
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">@SubmitButtonText</button>
            @if (!string.IsNullOrWhiteSpace(CancelHref))
            {
                <a href="@CancelHref" class="btn btn-secondary">Cancel</a>
            }
        </div>
    </fieldset>
</EditForm>

@code {
    [Parameter] public EventFormInput Input { get; set; } = new();
    [Parameter] public IReadOnlyList<SpeakerOption>? SpeakerOptions { get; set; }
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public bool IsSpeakersLoading { get; set; }
    [Parameter] public string? SpeakersError { get; set; }
    [Parameter] public string SubmitButtonText { get; set; } = "Submit";
    [Parameter] public string? CancelHref { get; set; }
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public EventCallback<int> OnToggleSpeaker { get; set; }
    [Parameter] public EventCallback OnNameBlur { get; set; }

    private string descriptionTab = "edit";
    private string descriptionHtml = string.Empty;

    private void ShowPreview()
    {
        descriptionHtml = MarkdownService.ToHtml(Input.Description);
        descriptionTab = "preview";
    }

    private void HandleNameBlur()
    {
        OnNameBlur.InvokeAsync();
    }

    private void ToggleSpeaker(int speakerId, ChangeEventArgs args)
    {
        OnToggleSpeaker.InvokeAsync(speakerId);
    }
}
